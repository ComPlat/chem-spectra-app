flowchart TB
  subgraph eln [Chemotion ELN]
    ELNFrontend["ELN frontend\nReact UI"]
    ChemSpectraFrontend["ChemSpectra React components\nChemSpectraClient / SpectraEditor"]
    ELNBackend["ELN backend\nRails proxy and attachments"]
  end

  subgraph processing [Processing Service]
    App["chem-spectra-app\nFlask conversion and prediction"]
  end

  subgraph external [External Processing]
    NMRShiftDB["NMRShiftDB compatible\nURL_NSHIFTDB"]
    DeepIR["DeepIR\nURL_DEEPIR"]
    MSConvert["msconvert Docker\nmsconvert_docker"]
  end

  ELNFrontend -->|"renders"| ChemSpectraFrontend
  ChemSpectraFrontend -->|"props and callbacks"| ELNFrontend
  ELNFrontend -->|"ELN API requests"| ELNBackend
  ELNBackend -->|"HTTP conversion and prediction"| App
  App -->|"ZIP, JSON, headers"| ELNBackend
  ELNBackend -->|"attachments and JSON"| ELNFrontend
  App -.->|"NMR prediction"| NMRShiftDB
  App -.->|"IR prediction"| DeepIR
  App -.->|"RAW conversion"| MSConvert

